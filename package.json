{
  "name": "irl-system-v1",
  "version": "1.0.0",
  "description": "IRL Broadcast Controller V1 - Powered by Kamar Broadcast",
  "main": "main.js",
  "scripts": {
    "start": "electron .",
    "build": "electron-builder --win"
  },
  "build": {
    "appId": "com.kamarbroadcast.irlsystem",
    "productName": "IRL System V1",
    "win": {
      "target": "nsis",
      "icon": "icon.png"
    },
    "nsis": {
      "include": "build/installer.nsh"
    },
    "extraResources": [
      "mediamtx.exe",
      "mediamtx.yml",
      "ffmpeg.exe"
    ],
    "asar": true
  },
  "dependencies": {
    "axios": "^1.16.1",
    "electron-updater": "^6.8.3",
    "fluent-ffmpeg": "^2.1.3",
    "node-machine-id": "^1.1.12"
  },
  "devDependencies": {
    "electron": "^29.0.0",
    "electron-builder": "^24.13.3"
  }
  {
